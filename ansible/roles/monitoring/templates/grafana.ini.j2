[server]
http_port = 3000
domain = vm-monitoring
root_url = %(protocol)s://%(domain)s:%(http_port)s/

[security]
# Identifiants admin injectés via GF_SECURITY_ADMIN_USER / GF_SECURITY_ADMIN_PASSWORD
# (docker-compose.yml), pas en dur ici.
disable_gravatar = true

[users]
allow_sign_up = false
default_theme = dark

[analytics]
reporting_enabled = false
check_for_updates = false

[log]
mode = console
level = info

[databases]
* = host=127.0.0.1 port={{ postgres_ha_pgbouncer_target_port }} pool_size={{ postgres_ha_pgbouncer_pool_size }}

[pgbouncer]
listen_addr = 0.0.0.0
listen_port = {{ postgres_ha_pgbouncer_port }}
auth_type = md5
auth_file = /etc/pgbouncer/userlist.txt
pool_mode = transaction
max_client_conn = {{ postgres_ha_pgbouncer_max_client_conn }}
default_pool_size = {{ postgres_ha_pgbouncer_pool_size }}
log_connections = 0
log_disconnections = 0
log_pooler_errors = 1
ignore_startup_parameters = extra_float_digits

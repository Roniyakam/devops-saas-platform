[infra]
vm-infra ansible_host=<IP_VM_INFRA>

[k8s_master]
vm-k8s-master ansible_host=<IP_K8S_MASTER>

[k8s_workers]
vm-k8s-worker ansible_host=<IP_K8S_WORKER>

[postgres]
vm-postgres ansible_host=<IP_POSTGRES>

[monitoring]
vm-monitoring ansible_host=<IP_MONITORING>

[k8s_cluster:children]
k8s_master
k8s_workers

[scaleway:children]
infra
k8s_master
k8s_workers
postgres
monitoring

[scaleway:vars]
ansible_user = root
ansible_python_interpreter = /usr/bin/python3

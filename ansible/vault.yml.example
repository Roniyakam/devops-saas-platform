---
# EXEMPLE de fichier vault — NE JAMAIS committer vault.yml avec des vraies valeurs
# Créer vault.yml à partir de ce modèle et chiffrer avec : ansible-vault encrypt vault.yml
#
# Usage dans les playbooks :
#   ansible-playbook site.yml --vault-password-file ~/.vault_pass

# Clé SSH publique pour l'utilisateur devops (optionnel si gérée via ~/.ssh/authorized_keys)
# vault_devops_ssh_public_key: "ssh-ed25519 AAAA... user@host"

# Mot de passe replication Patroni (S3 - roles/postgres_ha, vm-postgres) —
# seul secret PostgreSQL porté par ce fichier : superuser et appuser vivent
# dans le Vault K8s (secret/postgres/superuser, secret/postgres/app),
# bootstrappés par playbooks/deploy-vault-secrets.yml.
# vault_postgres_replication_password: "changeme"

# Note : depuis la migration vers le stockage Raft, Vault ne dépend plus
# d'un vault_dev_root_token (mode dev supprimé). Le root token et la clé de
# unseal sont désormais générés par "vault operator init" et stockés dans
# ansible/vault-init.yml (chiffré ansible-vault, non commité — voir
# .gitignore et docs/architecture.md).

# Token Scaleway API (pour le provisioning Terraform futur)
# vault_scaleway_access_key: "SCWXXXXXXXXXXXXXXXXX"
# vault_scaleway_secret_key: "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
